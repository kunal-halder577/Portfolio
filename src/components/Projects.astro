---
// src/components/Projects.astro
import { projects, personal } from '@/data/config';
import ProjectCard from './ProjectCard.astro';
---

<section id="projects" class="relative py-16 md:py-28 px-6">
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="reveal mb-16">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <p class="text-indigo-400 font-medium text-sm tracking-widest uppercase mb-3">What I've Built</p>
          <h2 class="font-display text-4xl md:text-6xl font-semibold text-white mb-4">
            Featured Projects
          </h2>
          <p class="text-slate-400 text-lg max-w-xl leading-relaxed">
            Each project is a complete system — designed, engineered, and shipped end-to-end.
          </p>
        </div>

        <!-- View all on GitHub -->
        <a
          href={personal.github}
          target="_blank"
          rel="noopener noreferrer"
          class="self-start md:self-end flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-medium text-slate-400 hover:text-white glass-light border border-white/10 hover:border-indigo-500/30 transition-all duration-300 hover:shadow-glow-sm whitespace-nowrap"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
          All Projects on GitHub
        </a>
      </div>
    </div>

    <!-- Projects grid -->
    <div class="grid md:grid-cols-2 gap-6">
      {projects.map((project, i) => (
        <ProjectCard project={project} index={i} />
      ))}
    </div>

    <!-- If no projects are marked featured, show a placeholder -->
    {projects.length === 0 && (
      <div class="reveal text-center py-24 glass rounded-2xl border border-white/10">
        <p class="text-slate-500 text-lg">More projects coming soon...</p>
      </div>
    )}

  </div>

  <!-- BG accent -->
  <div class="absolute right-0 top-1/3 w-[500px] h-[500px] pointer-events-none"
    style="background: radial-gradient(ellipse at right, rgba(99,102,241,0.05) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
</section>
