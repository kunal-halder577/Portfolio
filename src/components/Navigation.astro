---
// src/components/Navigation.astro
import { navLinks, personal } from '@/data/config';
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50"
>
  <div class="relative max-w-7xl mx-auto px-6 py-4">
    <nav
      id="nav-inner"
      class="nav-bar flex items-center justify-between rounded-2xl px-6 py-3 border border-transparent transition-colors duration-500"
    >
      <!-- Logo / Name -->
      <a
        href="/"
        class="font-display text-xl font-semibold tracking-wide text-white hover:text-indigo-300 transition-colors duration-300"
      >
        <span class="text-shimmer">E.</span>
      </a>

      <!-- Desktop links -->
      <ul class="hidden md:flex items-center gap-1">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              data-navlink
              class="relative px-4 py-2 text-sm font-medium text-slate-400 hover:text-white rounded-lg transition-colors duration-200 hover:bg-white/5 group"
            >
              {link.label}
              <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-0 h-px bg-gradient-to-r from-indigo-400 to-violet-400 group-hover:w-5 transition-all duration-300 rounded-full"></span>
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA -->
      <a
        href={personal.resumeUrl}
        download
        class="hidden md:flex items-center gap-2 px-5 py-2 text-sm font-semibold text-white rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 transition-colors duration-200 shadow-glow-sm hover:shadow-glow-md"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
        Resume
      </a>

      <!-- Mobile hamburger -->
      <button
        id="menu-btn"
        class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-white/10 transition-colors duration-200"
        aria-label="Open menu"
      >
        <span id="bar1" class="w-5 h-0.5 bg-white rounded transition-transform duration-300"></span>
        <span id="bar2" class="w-5 h-0.5 bg-white rounded transition-opacity duration-300"></span>
        <span id="bar3" class="w-5 h-0.5 bg-white rounded transition-transform duration-300"></span>
      </button>
    </nav>

    <!-- Mobile menu — solid layered bg, no backdrop-filter -->
    <div
      id="mobile-menu"
      class="md:hidden hidden mt-2 mobile-menu-bg rounded-2xl overflow-hidden"
    >
      <ul class="flex flex-col p-4 gap-1">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class="mobile-nav-link block px-4 py-3 text-sm font-medium text-slate-300 hover:text-white hover:bg-white/5 rounded-xl transition-colors duration-200"
            >
              {link.label}
            </a>
          </li>
        ))}
        <li class="pt-2 border-t border-white/10 mt-1">
          <a
            href={personal.resumeUrl}
            download
            class="flex items-center justify-center gap-2 w-full px-4 py-3 text-sm font-semibold text-white rounded-xl bg-gradient-to-r from-indigo-600 to-violet-600"
          >
            Download Resume
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  /*
   * PERFORMANCE FIX
   * ─────────────────────────────────────────────────────────────────
   * Old approach: backdrop-filter: blur(Xpx)
   *   → Forces the browser to sample + blur every pixel behind the
   *     element on EACH frame. Triggers a new compositor layer AND
   *     an expensive texture sample pass — brutal on mid-range GPUs.
   *
   * New approach: layered opaque-ish background + box-shadow depth
   *   → Single composite layer promoted via will-change: transform.
   *     No per-frame blur sampling. Smooth 60 fps on all devices.
   * ─────────────────────────────────────────────────────────────────
   */

  /* Promote navbar to its own GPU layer once, upfront */
  #navbar {
    will-change: transform;
    /* 
      translateZ(0) nudges the browser to composite this layer
      independently so scroll repaints never touch it.
    */
    transform: translateZ(0);
  }

  .nav-bar {
    /* 
      Layered background:
        1. A semi-transparent dark base  → gives opacity / depth
        2. A subtle noise-like gradient  → replaces the "frosted" feel
      No backdrop-filter needed.
    */
    background:
      linear-gradient(
        135deg,
        rgba(15, 15, 30, 0.85) 0%,
        rgba(20, 16, 40, 0.80) 100%
      );
    border-color: rgba(255, 255, 255, 0.08);
    /*
      Multi-layer box-shadow:
        • Inner highlight at top edge  → mimics light catching glass
        • Soft outer glow              → separates nav from content
    */
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.10),
      0 4px 24px rgba(0, 0, 0, 0.40),
      0 1px 2px  rgba(0, 0, 0, 0.30);
  }

  /* Slightly deepen the shadow once the user scrolls */
  #navbar.scrolled .nav-bar {
    background:
      linear-gradient(
        135deg,
        rgba(10, 10, 22, 0.95) 0%,
        rgba(15, 10, 32, 0.92) 100%
      );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 8px 32px rgba(0, 0, 0, 0.55),
      0 2px 4px  rgba(0, 0, 0, 0.40);
  }

  /* Mobile menu uses same layered approach */
  .mobile-menu-bg {
    background:
      linear-gradient(
        160deg,
        rgba(15, 15, 30, 0.97) 0%,
        rgba(20, 14, 40, 0.95) 100%
      );
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.07),
      0 8px 28px rgba(0, 0, 0, 0.50);
  }

  /* Active nav link indicator */
  [data-navlink].nav-active {
    color: white;
  }
  [data-navlink].nav-active::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 20px;
    height: 1px;
    background: linear-gradient(to right, #818cf8, #a78bfa);
    border-radius: 999px;
  }
</style>

<script>
  // ── Scroll state ──────────────────────────────────────────────────
  // Use requestAnimationFrame to debounce scroll — avoids forced
  // layout recalculations on every scroll event.
  const navbar = document.getElementById('navbar');
  let ticking = false;

  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        navbar?.classList.toggle('scrolled', window.scrollY > 60);
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  // ── Mobile toggle ─────────────────────────────────────────────────
  const menuBtn    = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');
  let open = false;

  function openMenu() {
    open = true;
    mobileMenu?.classList.remove('hidden');
    bar1?.style.setProperty('transform', 'rotate(45deg) translate(4px, 4px)');
    bar2?.style.setProperty('opacity', '0');
    bar3?.style.setProperty('transform', 'rotate(-45deg) translate(4px, -4px)');
  }

  function closeMenu() {
    open = false;
    mobileMenu?.classList.add('hidden');
    bar1?.style.setProperty('transform', '');
    bar2?.style.setProperty('opacity', '1');
    bar3?.style.setProperty('transform', '');
  }

  menuBtn?.addEventListener('click', () => open ? closeMenu() : openMenu());

  document.querySelectorAll('.mobile-nav-link').forEach(el => {
    el.addEventListener('click', closeMenu);
  });
</script>