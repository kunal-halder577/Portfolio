---
// src/components/Experience.astro
import { experience } from '@/data/config';

const iconPaths: Record<string, string> = {
  code:       'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  graduation: 'M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222',
  rocket:     'M12 19l9 2-9-18-9 18 9-2zm0 0v-8',
  star:       'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
};
---

<section id="experience" class="relative py-28 px-6">
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="reveal mb-16 text-center">
      <p class="text-indigo-400 font-medium text-sm tracking-widest uppercase mb-3">Journey So Far</p>
      <h2 class="font-display text-5xl md:text-6xl font-semibold text-white mb-4">
        Experience
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto leading-relaxed">
        Self-directed, research-backed, and shipping real products from day one.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative max-w-3xl mx-auto">
      <!-- Vertical spine -->
      <div
        class="absolute left-6 md:left-1/2 md:-translate-x-px top-0 bottom-0 w-px"
        style="background: linear-gradient(to bottom, transparent, rgba(99,102,241,0.5) 5%, rgba(99,102,241,0.5) 95%, transparent);"
        aria-hidden="true"
      ></div>

      <div class="space-y-10">
        {experience.map((item, i) => {
          const isFocus = item.type === 'focus';
          const isLeft  = i % 2 === 0;

          return (
            <div
              class:list={[
                'reveal relative flex gap-8 md:gap-0',
                isLeft ? 'md:flex-row' : 'md:flex-row-reverse',
              ]}
              data-delay={String(i * 0.15)}
            >
              <!-- Timeline dot -->
              <div class="relative z-10 flex-shrink-0 flex items-start justify-center md:absolute md:left-1/2 md:-translate-x-1/2 md:top-6 mt-5 md:mt-0">
                <div
                  class:list={[
                    'w-12 h-12 rounded-2xl flex items-center justify-center border transition-all duration-300',
                    isFocus
                      ? 'bg-gradient-to-br from-indigo-600 to-violet-600 border-indigo-500/50 timeline-dot shadow-glow-md'
                      : 'glass border-white/10 hover:border-indigo-500/30',
                  ]}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class:list={['h-5 w-5', isFocus ? 'text-white' : 'text-indigo-400']}
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[item.icon]} />
                  </svg>
                </div>
              </div>

              <!-- Card -->
              <div class:list={['w-full md:w-[calc(50%-40px)] pl-0 md:px-6', isLeft ? 'md:pr-10' : 'md:pl-10']}>
                <div
                  class:list={[
                    'relative group rounded-2xl p-6 border transition-all duration-500',
                    isFocus
                      ? 'glass border-indigo-500/30 shadow-glow-sm hover:shadow-glow-md'
                      : 'glass-light border-white/[0.07] hover:border-white/15',
                  ]}
                >
                  <!-- Focus card: pulsing top accent -->
                  {isFocus && (
                    <div
                      class="absolute top-0 left-0 right-0 h-px rounded-t-2xl animate-pulse-slow"
                      style="background: linear-gradient(90deg, transparent, rgba(99,102,241,0.8), rgba(139,92,246,0.8), transparent);"
                    ></div>
                  )}

                  <!-- Period badge -->
                  <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-indigo-950/60 text-indigo-300 border border-indigo-800/40 mb-3">
                    {item.period}
                  </span>

                  <!-- Title -->
                  <h3 class:list={['font-display text-xl font-semibold mb-1', isFocus ? 'text-shimmer' : 'text-white']}>
                    {item.title}
                  </h3>

                  <!-- Org -->
                  <p class="text-sm font-medium text-indigo-400 mb-3">{item.org}</p>

                  <!-- Description -->
                  <p class="text-slate-400 text-sm leading-relaxed mb-4">{item.description}</p>

                  <!-- Bullets -->
                  <ul class="space-y-2">
                    {item.bullets.map(bullet => (
                      <li class="flex items-start gap-2.5 text-slate-400 text-sm">
                        <span class="flex-shrink-0 mt-1.5 w-1 h-1 rounded-full bg-indigo-500"></span>
                        {bullet}
                      </li>
                    ))}
                  </ul>

                  <!-- Focus-specific CTA -->
                  {isFocus && (
                    <a
                      href="#contact"
                      class="inline-flex items-center gap-2 mt-5 px-4 py-2 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 transition-all duration-300 shadow-glow-sm hover:shadow-glow-md"
                    >
                      Let's Connect
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- BG accent -->
  <div class="absolute left-0 top-1/2 w-[400px] h-[400px] pointer-events-none"
    style="background: radial-gradient(ellipse at left, rgba(139,92,246,0.05) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
</section>
