---
// src/components/Hero.astro
import { personal, projects, skills } from '@/data/config';

// Derive dynamic values — change config.ts, never touch this file again
const firstName = personal.name;
const liveCount = projects.filter(p => p.status === 'live').length;
const topSkills = skills.slice(0, 5).map(s => s.name);
const recentCommits = projects.slice(0, 3).map(p => ({
  hash: Math.random().toString(36).slice(2, 9),
  msg:  `feat: ship ${p.name.toLowerCase().replace(/\s+/g, '-')}`,
}));

// Split "X & Y" title into two lines for styled rendering
const titleParts = personal.title.split(' & ');
const titleLine1 = titleParts[0];                        // e.g. "Full-Stack Developer"
const titleLine2 = titleParts[1] ?? '';                  // e.g. "DevOps Enthusiast"
---

<section
  id="hero"
  class="relative min-h-[100svh] flex items-center justify-center overflow-hidden px-6"
>
  <!-- Decorative grid lines -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute inset-0"
      style="background-image: linear-gradient(rgba(99,102,241,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(99,102,241,0.04) 1px, transparent 1px); background-size: 80px 80px;"
    ></div>
    <!-- Radial vignette to fade the grid -->
    <div class="absolute inset-0"
      style="background: radial-gradient(ellipse 70% 60% at 50% 50%, transparent 30%, #07071a 100%);"
    ></div>
  </div>

  <div class="relative max-w-7xl mx-auto w-full">
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center min-h-[100svh] py-20 lg:py-32">

      <!-- ── Text column ── -->
      <div class="flex flex-col gap-8 lg:pr-8">
        <!-- Status badge -->
        <div class="hero-badge self-start flex items-center gap-2 px-4 py-2 rounded-full glass-light text-sm text-slate-400 border border-white/10">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
          </span>
          Open to opportunities
        </div>

        <!-- Greeting -->
        <div>
          <p class="hero-hello font-sans text-indigo-400 font-medium text-lg mb-2 tracking-widest uppercase">
            Hi, I'm
          </p>
          <h1
            class="hero-name font-display leading-none"
            style="font-size: clamp(3.5rem, 10vw, 7.5rem); font-weight: 700;"
          >
            <span class="text-white">{firstName}</span><span class="text-shimmer-perf">.</span>
          </h1>
          <h2 class="hero-title font-display font-medium text-slate-300 mt-2" style="font-size: clamp(1.2rem, 3vw, 2rem); line-height: 1.3;">
            {titleLine1} &amp;<br/>
            <span class="text-gradient-violet">{titleLine2}</span>
          </h2>
        </div>

        <!-- Tagline -->
        <p class="hero-tagline font-sans text-slate-400 text-lg leading-relaxed max-w-lg"
          style="contain: content;">
          {personal.tagline}
        </p>

        <!-- CTA row -->
        <div class="hero-ctas flex flex-wrap gap-4">
          <a
            href="#projects"
            class="group relative inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-semibold text-white overflow-hidden transition-all duration-300"
          >
            <!-- Animated gradient background -->
            <span class="absolute inset-0 bg-gradient-to-r from-indigo-600 to-violet-600 transition-all duration-500 group-hover:from-indigo-500 group-hover:to-violet-500"></span>
            <span class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500"
              style="background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);"
            ></span>
            <span class="relative flex items-center gap-2">
              View My Work
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </a>

          <a
            href={personal.resumeUrl}
            download
            class="group inline-flex items-center gap-2 px-7 py-3.5 rounded-xl font-semibold text-slate-300 hover:text-white glass-light border border-white/10 hover:border-indigo-500/50 transition-all duration-300 hover:shadow-glow-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:-translate-y-0.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
            </svg>
            Grab My Resume
          </a>
        </div>

        <!-- Social links -->
        <div class="hero-social flex items-center gap-5 pt-2">
          <a href={personal.github} target="_blank" rel="noopener noreferrer"
            class="text-slate-500 hover:text-white transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(99,102,241,0.8)]"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href={personal.linkedin} target="_blank" rel="noopener noreferrer"
            class="text-slate-500 hover:text-white transition-colors duration-300 hover:drop-shadow-[0_0_8px_rgba(99,102,241,0.8)]"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <div class="h-px flex-1 bg-gradient-to-r from-slate-700/60 to-transparent max-w-[120px]"></div>
          <span class="text-slate-600 text-xs font-mono">{personal.location}</span>
        </div>
      </div>

    
     <div class="hero-card relative hidden">

  <div class="glow-ring glow-ring--indigo"></div>
  <div class="glow-ring glow-ring--violet"></div>


  <div class="relative card-float">

   
    <div class="hero-terminal rounded-2xl p-6 w-full max-w-md">

     
      <div class="flex items-center gap-2 mb-5 pb-4 border-b border-white/10">
        <div class="flex gap-1.5">
          <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
        </div>
        <span class="text-slate-500 text-xs font-mono ml-auto">~/portfolio</span>
      </div>

      <div class="font-mono text-sm space-y-2">
        <div class="text-slate-500">
          <span class="text-indigo-400">$</span> whoami
        </div>
        <div class="text-emerald-400 font-medium">{personal.fullName.toLowerCase().replace(' ', '_')}</div>

        <div class="pt-1 text-slate-500">
          <span class="text-indigo-400">$</span> cat skills.json | jq '.top'
        </div>
        <div class="text-slate-300 leading-relaxed">
          <span class="text-yellow-400">[</span>
          {topSkills.map((s, i) => (
            <span>
              <span class="text-sky-300">"{s}"</span>{i < topSkills.length - 1 ? ', ' : ''}
            </span>
          ))}
          <span class="text-yellow-400">]</span>
        </div>

        <div class="pt-1 text-slate-500">
          <span class="text-indigo-400">$</span> git log --oneline -3
        </div>
        <div class="space-y-1 text-xs">
          {recentCommits.map(c => (
            <p>
              <span class="text-violet-400">{c.hash}</span>{' '}
              <span class="text-slate-300">{c.msg}</span>
            </p>
          ))}
        </div>

        <div class="pt-1 flex items-center gap-1 text-slate-500">
          <span class="text-indigo-400">$</span>
          <span class="terminal-cursor w-2 h-4 bg-indigo-400 inline-block"></span>
        </div>
      </div>

      <!-- Corner accent — static, no animation needed -->
      <div class="corner-accent absolute top-0 right-0 w-32 h-32 pointer-events-none"></div>
    </div>

    <!--
      FLOATING BADGES
      Old: glass class = backdrop-filter on a tiny element that animates
           every frame → extremely wasteful.
      New: opaque layered background, same visual weight.
           will-change:transform tells the compositor to keep these
           on their own layer so the float animation is free.
    -->
    <div class="badge badge--live absolute -top-4 -right-4">
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
      {liveCount} Project{liveCount !== 1 ? 's' : ''} Live
    </div>

    <div class="badge badge--stack absolute -bottom-4 -left-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
      </svg>
      Full-Stack + DevOps
    </div>
  </div>
</div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-600 text-xs">
      <span>scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-slate-600 to-transparent"></div>
    </div>
  </div>
</section>

<style>
  .text-gradient-violet {
    background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  /* Staggered entrance animations */
  .hero-badge  { animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both; }
  .hero-hello  { animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s both; }
  .hero-name   { animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both; }
  .hero-title  { animation: slideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both; }
  .hero-tagline{ animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both; }
  .hero-ctas   { animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.65s both; }
  .hero-social { animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.75s both; }
  .hero-card   { animation: slideUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s both; }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  /* ───────────────────────────────────────────────
     KEYFRAMES
     Every animation here touches ONLY transform or
     opacity — the two properties that are handled
     entirely on the GPU compositor thread.
     No color, no background, no filter, no size.
  ─────────────────────────────────────────────── */

  @keyframes glowBreathe {
    0%, 100% { opacity: 0.6; transform: scale(1);    }
    50%       { opacity: 1;   transform: scale(1.08); }
  }

  @keyframes floatY {
    0%, 100% { transform: translateY(0);    }
    50%       { transform: translateY(-10px); }
  }

  @keyframes cursorBlink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  /* ───────────────────────────────────────────────
     GLOW RINGS
     Color lives in the element itself (one-time paint).
     Only opacity + scale animate → zero repaint.
  ─────────────────────────────────────────────── */
  .glow-ring {
    position: absolute;
    border-radius: 9999px;
    /* 
      will-change:transform promotes to compositor layer up front,
      so the scale animation never hits the main thread.
    */
    will-change: transform, opacity;
  }

  .glow-ring--indigo {
    width: 20rem; height: 20rem;
    background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%);
    animation: glowBreathe 5s ease-in-out infinite;
  }

  .glow-ring--violet {
    width: 24rem; height: 24rem;
    background: radial-gradient(circle, rgba(139,92,246,0.10) 0%, transparent 70%);
    animation: glowBreathe 5s ease-in-out infinite;
    animation-delay: -2.5s;
  }

  /* ───────────────────────────────────────────────
     CARD FLOAT WRAPPER
     Wrapping the float animation in a dedicated
     element keeps the transform separate from the
     card's own stacking context.
  ─────────────────────────────────────────────── */
  .card-float {
    will-change: transform;
    animation: floatY 6s ease-in-out infinite;
  }

  
  .hero-terminal {
    contain: paint;
    background:
      linear-gradient(
        135deg,
        rgba(13, 15, 43, 0.92) 0%,
        rgba(19, 21, 77,  0.75) 100%
      );
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      /* top-edge glass highlight */
      inset 0 1px 0   rgba(255, 255, 255, 0.10),
      /* glow border effect */
      0 0 0 1px       rgba(99, 102, 241, 0.15),
      0 0 24px        rgba(99, 102, 241, 0.10),
      /* depth shadow */
      0 20px 60px     rgba(0, 0, 0, 0.50),
      0 4px  12px     rgba(0, 0, 0, 0.35);
  }

  /* Static corner gradient — no animation, no cost */
  .corner-accent {
    background: radial-gradient(
      circle at top right,
      rgba(139, 92, 246, 0.15) 0%,
      transparent 70%
    );
    border-radius: 0 1rem 0 0;
  }


  .badge {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.35);
    will-change: transform;
  }

  .badge--live {
    background: linear-gradient(135deg, rgba(6,20,40,0.95), rgba(6,28,30,0.90));
    border: 1px solid rgba(52, 211, 153, 0.20);
    color: rgb(52, 211, 153);
    animation: floatY 4s ease-in-out infinite;
    animation-delay: -1s;
  }

  .badge--stack {
    background: linear-gradient(135deg, rgba(13,10,40,0.95), rgba(18,14,50,0.90));
    border: 1px solid rgba(99, 102, 241, 0.20);
    color: rgb(165, 180, 252);
    animation: floatY 5s ease-in-out infinite;
    animation-delay: -3s;
  }

  /* ───────────────────────────────────────────────
     TERMINAL CURSOR
  ─────────────────────────────────────────────── */
  .terminal-cursor {
    /* opacity-only blink — no layout, no paint */
    animation: cursorBlink 1.2s step-end infinite;
  }

  /* ───────────────────────────────────────────────
     TEXT SHIMMER
     The shimmer uses background-clip:text + an
     animating background-position.
     Isolating it on its own compositor layer with
     will-change prevents the animation from
     invalidating the parent's paint record.
  ─────────────────────────────────────────────── */
  .text-shimmer-perf {
    /* Preserve existing shimmer look from global styles */
    background: linear-gradient(
      90deg,
      #818cf8 0%,
      #c4b5fd 40%,
      #818cf8 80%
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmerSlide 3s linear infinite;
    /*
      Critical: isolate this element so its animated
      background never triggers a repaint on the <h1>
      or any sibling text.
    */
    will-change: background-position;
    display: inline-block;
  }

  @keyframes shimmerSlide {
    from { background-position: 200% center; }
    to   { background-position:   0% center; }
  }
</style>
