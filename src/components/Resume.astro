---
// src/components/Resume.astro
import { personal, experience, projects } from '@/data/config';

// Build preview data dynamically from config
const expPreview = experience
  .filter(e => e.type !== 'focus')
  .slice(0, 2)
  .map(e => ({ role: e.title, period: e.period, desc: e.bullets[0] ?? e.description }));

const projectPreview = projects.slice(0, 2).map(p => ({
  name: p.name,
  desc: p.description,
}));

// Education entry is the one with type === 'education'
const eduEntry = experience.find(e => e.type === 'education');
---

<section id="resume" class="relative py-28 px-6">
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="reveal mb-16 text-center">
      <p class="text-indigo-400 font-medium text-sm tracking-widest uppercase mb-3">On Paper</p>
      <h2 class="font-display text-5xl md:text-6xl font-semibold text-white mb-4">
        Resume
      </h2>
      <p class="text-slate-400 text-lg max-w-lg mx-auto leading-relaxed">
        A condensed view of skills, projects, and education. Download the full PDF below.
      </p>
    </div>

    <!-- Resume preview card -->
    <div class="reveal max-w-4xl mx-auto">
      <div class="glow-border glass rounded-2xl overflow-hidden border border-white/[0.08]">

        <!-- Fake PDF preview -->
        <div class="relative p-8 md:p-12" style="background: linear-gradient(135deg, rgba(13,15,43,0.8) 0%, rgba(19,21,77,0.5) 100%);">
          <!-- Header -->
          <div class="absolute top-0 left-0 right-0 h-1"
            style="background: linear-gradient(90deg, #6366f1, #8b5cf6, #38bdf8);"
          ></div>

          <div class="flex flex-col md:flex-row gap-8 items-start">
            <!-- Left column -->
            <div class="flex-1">
              <h3 class="font-display text-3xl font-semibold text-white mb-1">{personal.fullName}</h3>
              <p class="text-indigo-400 font-medium mb-4">{personal.title}</p>
              <p class="text-slate-400 text-sm leading-relaxed mb-6 max-w-sm">
                {personal.tagline}
              </p>

              <!-- Contact info -->
              <div class="space-y-2 mb-8">
                {[
                  { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', text: personal.email },
                  { icon: 'M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z', text: personal.location },
                  { icon: 'M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14', text: personal.github.replace('https://', '') },
                ].map(item => (
                  <div class="flex items-center gap-2.5 text-slate-400 text-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-indigo-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
                    </svg>
                    {item.text}
                  </div>
                ))}
              </div>

              <!-- Skills preview -->
              <div class="mb-6">
                <h4 class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3">Core Skills</h4>
                <div class="flex flex-wrap gap-2">
                  {['React', 'Node.js', 'TypeScript', 'Docker', 'K8s', 'PostgreSQL', 'AWS', 'Terraform'].map(skill => (
                    <span class="px-2.5 py-1 rounded-lg text-xs font-medium text-slate-300 bg-white/5 border border-white/10">
                      {skill}
                    </span>
                  ))}
                </div>
              </div>
            </div>

            <!-- Right column - mini sections -->
            <div class="flex-1 space-y-6">
              {/* Experience preview */}
              <div>
                <h4 class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3 flex items-center gap-2">
                  <span class="w-4 h-px bg-indigo-600"></span>
                  Experience
                </h4>
                <div class="space-y-3">
                  {expPreview.map(exp => (
                    <div class="pl-3 border-l border-indigo-800/50">
                      <p class="text-white text-sm font-medium">{exp.role}</p>
                      <p class="text-indigo-400 text-xs mb-1">{exp.period}</p>
                      <p class="text-slate-400 text-xs leading-relaxed">{exp.desc}</p>
                    </div>
                  ))}
                </div>
              </div>

              {/* Projects preview */}
              <div>
                <h4 class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3 flex items-center gap-2">
                  <span class="w-4 h-px bg-violet-600"></span>
                  Projects
                </h4>
                <div class="space-y-3">
                  {projectPreview.map(p => (
                    <div class="pl-3 border-l border-violet-800/50">
                      <p class="text-white text-sm font-medium">{p.name}</p>
                      <p class="text-slate-400 text-xs">{p.desc}</p>
                    </div>
                  ))}
                </div>
              </div>

              {/* Education preview */}
              {eduEntry && (
                <div>
                  <h4 class="text-xs font-semibold tracking-widest uppercase text-slate-500 mb-3 flex items-center gap-2">
                    <span class="w-4 h-px bg-sky-700"></span>
                    Education
                  </h4>
                  <div class="pl-3 border-l border-sky-900/50">
                    <p class="text-white text-sm font-medium">{eduEntry.title}</p>
                    <p class="text-slate-400 text-xs">{eduEntry.org} · {eduEntry.period}</p>
                  </div>
                </div>
              )}
            </div>
          </div>

          <!-- Blurred "more content" indicator -->
          <div class="absolute bottom-0 left-0 right-0 h-24 pointer-events-none"
            style="background: linear-gradient(to top, rgba(13,15,43,0.95) 0%, transparent 100%);"
          ></div>
        </div>
      </div>

      <!-- Download button -->
      <div class="flex flex-col sm:flex-row items-center gap-4 justify-center mt-8">
        <a
          href={personal.resumeUrl}
          download
          class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-2xl font-semibold text-white text-lg overflow-hidden transition-all duration-300 hover:scale-[1.02]"
        >
          <!-- Animated glow background -->
          <span class="absolute inset-0 bg-gradient-to-r from-indigo-600 via-violet-600 to-indigo-600 bg-[length:200%_100%] animate-shimmer"></span>
          <!-- Outer glow ring -->
          <span class="absolute inset-0 rounded-2xl"
            style="box-shadow: 0 0 0 0 rgba(99,102,241,0.4); animation: glowPulse 2s ease-in-out infinite;"
          ></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="relative h-5 w-5 group-hover:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
          <span class="relative">Download Full Resume (PDF)</span>
        </a>

        <span class="text-slate-600 text-sm">— or view the sections above</span>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes glowPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(99,102,241,0.4); }
    50%       { box-shadow: 0 0 24px 4px rgba(99,102,241,0.25); }
  }

  @keyframes shimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 200% center; }
  }

  .animate-shimmer {
    animation: shimmer 3s linear infinite;
  }
</style>
