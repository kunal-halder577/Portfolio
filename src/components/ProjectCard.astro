---
// src/components/ProjectCard.astro
// Reusable project card. Accepts a Project object from config.ts.
import type { Project } from '@/data/config';

interface Props {
  project: Project;
  index?:  number; // for staggered animation delay
}

const { project, index = 0 } = Astro.props;

const statusMap = {
  live:     { label: 'Live',     color: 'text-emerald-400', dot: 'bg-emerald-400' },
  wip:      { label: 'In Progress', color: 'text-amber-400',  dot: 'bg-amber-400' },
  archived: { label: 'Archived', color: 'text-slate-500',   dot: 'bg-slate-500' },
};
const status = statusMap[project.status];
---

<article
  class="project-card reveal group relative rounded-2xl overflow-hidden transition-all duration-500 hover:-translate-y-2 cursor-pointer"
  data-delay={String(index * 0.12)}
>
  <!-- Glow border (gradient border on hover) -->
  <div
    class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-0"
    style={`background: linear-gradient(135deg, rgba(99,102,241,0.5) 0%, rgba(139,92,246,0.3) 50%, rgba(56,189,248,0.4) 100%); padding: 1px;`}
    aria-hidden="true"
  >
    <div class="absolute inset-[1px] rounded-2xl bg-abyss"></div>
  </div>

  <!-- Card body -->
  <div
    class="relative z-10 h-full flex flex-col glass p-7 rounded-2xl border border-white/[0.07] group-hover:border-transparent transition-all duration-500"
    style="background: linear-gradient(135deg, rgba(13,15,43,0.7) 0%, rgba(19,21,77,0.5) 100%);"
  >
    <!-- Gradient accent top -->
    <div
      class={`absolute top-0 left-0 right-0 h-px bg-gradient-to-r ${project.gradient.replace('/20', '/40')} opacity-0 group-hover:opacity-100 transition-opacity duration-500`}
    ></div>

    <!-- Interior glow -->
    <div
      class={`absolute top-0 right-0 w-48 h-48 rounded-full pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500`}
      style={`background: radial-gradient(circle at top right, rgba(99,102,241,0.08) 0%, transparent 70%);`}
    ></div>

    <!-- Header row -->
    <div class="flex items-start justify-between mb-4">
      <!-- Project icon placeholder -->
      <div class={`w-11 h-11 rounded-xl bg-gradient-to-br ${project.gradient} flex items-center justify-center border border-white/10`}>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </div>

      <!-- Status badge -->
      <div class="flex items-center gap-1.5">
        <span class={`w-1.5 h-1.5 rounded-full ${status.dot} ${project.status === 'live' ? 'animate-pulse' : ''}`}></span>
        <span class={`text-xs font-medium ${status.color}`}>{status.label}</span>
      </div>
    </div>

    <!-- Title -->
    <h3 class="font-display text-2xl font-semibold text-white mb-2 group-hover:text-shimmer transition-colors duration-300">
      {project.name}
    </h3>

    <!-- Short description -->
    <p class="text-slate-500 text-sm font-medium mb-3">{project.description}</p>

    <!-- Long description -->
    <p class="text-slate-400 text-sm leading-relaxed mb-6 flex-1">
      {project.longDesc}
    </p>

    <!-- Tech tags -->
    <div class="flex flex-wrap gap-2 mb-6">
      {project.tags.map(tag => (
        <span class="px-2.5 py-1 rounded-lg text-xs font-medium text-slate-400 bg-white/5 border border-white/[0.07] group-hover:border-indigo-500/20 transition-colors duration-300">
          {tag}
        </span>
      ))}
    </div>

    <!-- CTA links -->
    <div class="flex items-center gap-3 pt-4 border-t border-white/[0.07]">
      <a
        href={project.liveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-white bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 transition-all duration-300 shadow-glow-sm hover:shadow-glow-md"
        onclick="event.stopPropagation()"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
        Live Demo
      </a>
      <a
        href={project.githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white glass-light border border-white/10 hover:border-white/20 transition-all duration-300"
        onclick="event.stopPropagation()"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</article>

<style>
  .project-card:hover .text-shimmer {
    background: linear-gradient(90deg, #a5b4fc 0%, #f8fafc 30%, #818cf8 50%, #f8fafc 70%, #a5b4fc 100%);
    background-size: 200% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: shimmer 3s linear infinite;
  }
</style>
