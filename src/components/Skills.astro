---
// src/components/Skills.astro
import { skills } from '@/data/config';
import SkillBadge from './SkillBadge.astro';

// Group by category
const categories = [...new Set(skills.map(s => s.category))];
const grouped = Object.fromEntries(
  categories.map(cat => [cat, skills.filter(s => s.category === cat)])
);

// Flatten for marquee (duplicate for seamless loop)
const marqueeSkills = [...skills, ...skills];
---

<section id="skills" class="relative py-16 md:py-28 px-6 overflow-hidden">
  <!-- Section fade-in container -->
  <div class="max-w-7xl mx-auto">

    <!-- Section header -->
    <div class="reveal mb-16 text-center">
      <p class="text-indigo-400 font-medium text-sm tracking-widest uppercase mb-3">My Arsenal</p>
      <h2 class="font-display text-4xl md:text-6xl font-semibold text-white mb-4">
        Skills & Technologies
      </h2>
      <p class="text-slate-400 text-lg max-w-xl mx-auto leading-relaxed">
        A curated toolkit refined through building real-world products from scratch.
      </p>
    </div>

    <!-- Grouped badges grid -->
    <div class="space-y-10 mb-20">
      {categories.map((cat, ci) => (
        <div class="reveal" data-delay={String(ci * 0.1)}>
          <!-- Category label -->
          <div class="flex items-center gap-4 mb-5">
            <span class="text-xs font-semibold tracking-widest uppercase text-slate-500">{cat}</span>
            <div class="h-px flex-1 bg-gradient-to-r from-slate-700/60 to-transparent max-w-xs"></div>
          </div>

          <!-- Badges -->
          <div class="flex flex-wrap gap-3">
            {grouped[cat].map((skill, i) => (
              <div
                class="reveal"
                data-delay={String(ci * 0.1 + i * 0.05)}
              >
                <SkillBadge skill={skill} size="md" />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- ── Marquee ── -->
    <div class="reveal">
      <div class="relative">
        <!-- Label -->
        <div class="text-center mb-8">
          <span class="text-xs font-medium tracking-widest uppercase text-slate-600">All Technologies</span>
        </div>

        <!-- Marquee track -->
        <div class="marquee-wrap">
          <div class="flex gap-4" style="animation: marquee 32s linear infinite; width: max-content;">
            {marqueeSkills.map(skill => (
              <SkillBadge skill={skill} size="sm" />
            ))}
          </div>
        </div>

        <!-- Reverse marquee -->
        <div class="marquee-wrap mt-4">
          <div class="flex gap-4" style="animation: marquee 32s linear infinite reverse; width: max-content; animation-delay: -16s;">
            {[...marqueeSkills].reverse().map(skill => (
              <SkillBadge skill={skill} size="sm" />
            ))}
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Decorative background element -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] pointer-events-none"
    style="background: radial-gradient(ellipse, rgba(79,70,229,0.04) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
</section>

<style>
  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
