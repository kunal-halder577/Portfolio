---
// src/layouts/Layout.astro
import '@/styles/global.css';
import { seo } from '@/data/config';

interface Props {
  title?:       string;
  description?: string;
}

const {
  title       = seo.title,
  description = seo.description,
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords"    content={seo.keywords} />
    <meta name="author"      content={seo.title.split('—')[0].trim()} />
    <link rel="canonical"    href={seo.siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={seo.siteUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={seo.ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:site"        content={seo.twitterHandle} />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={seo.ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts: Cormorant Garamond (display) + Syne (sans) + JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Schema.org JSON-LD — all values from config.ts via seo object -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name":     seo.title.split('—')[0].trim(),
      "jobTitle": seo.title.split('—')[1]?.trim() ?? '',
      "url":      seo.siteUrl,
      "sameAs":   [seo.siteUrl],
    })} />
  </head>

  <body class="bg-void text-slate-100 font-sans antialiased overflow-x-hidden">
    <!-- Ambient background layer -->
    <div class="fixed inset-0 pointer-events-none z-0 overflow-hidden" aria-hidden="true">
      <!-- Deep gradient base -->
      <div class="absolute inset-0 bg-gradient-to-br from-void via-abyss to-[#0c0830]"></div>
      


      <!-- Noise texture -->
      <div class="noise"></div>
    </div>

    <!-- Canvas particle system -->
    <canvas id="particles" class="fixed inset-0 pointer-events-none z-0" aria-hidden="true"></canvas>

    <!-- Page content -->
    <div class="relative z-10">
      <slot />
    </div>

    <style is:global>
      /* ── Reset + base ── */
      *, *::before, *::after { box-sizing: border-box; }

      html { color-scheme: dark; }

      ::selection {
        background: rgba(99, 102, 241, 0.35);
        color: #f1f5f9;
      }

      ::-webkit-scrollbar        { width: 6px; }
      ::-webkit-scrollbar-track  { background: #07071a; }
      ::-webkit-scrollbar-thumb  { background: #3730a3; border-radius: 999px; }
      ::-webkit-scrollbar-thumb:hover { background: #6366f1; }


      /* ── Noise overlay ── */
      .noise {
        position: absolute;
        inset: 0;
        opacity: 0.025;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        background-size: 256px;
      }

      /* ── Reveal animation (JS-powered) ── */
      .reveal {
        opacity: 0;
        transform: translateY(36px);
        transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                    transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.revealed {
        opacity: 1;
        transform: translateY(0);
      }

      /* ── Glassmorphism utility ── */
      .glass {
        background: rgba(13, 15, 43, 0.55);
        backdrop-filter: blur(16px) saturate(150%);
        -webkit-backdrop-filter: blur(16px) saturate(150%);
        border: 1px solid rgba(255, 255, 255, 0.06);
      }

      .glass-light {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.07);
      }

      /* ── Shimmer text ── */
      .text-shimmer {
        background: linear-gradient(
          90deg,
          #a5b4fc 0%,
          #f8fafc 30%,
          #818cf8 50%,
          #f8fafc 70%,
          #a5b4fc 100%
        );
        background-size: 200% auto;
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmer 4s linear infinite;
      }

      @keyframes shimmer {
        0%   { background-position: -200% center; }
        100% { background-position:  200% center; }
      }

      /* ── Glow border ── */
      .glow-border {
        position: relative;
      }
      .glow-border::before {
        content: '';
        position: absolute;
        inset: -1px;
        border-radius: inherit;
        padding: 1px;
        background: linear-gradient(135deg, rgba(99,102,241,0.6), rgba(139,92,246,0.3), rgba(56,189,248,0.4));
        -webkit-mask:
          linear-gradient(#fff 0 0) content-box,
          linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.35s ease;
      }
      .glow-border:hover::before { opacity: 1; }

      /* ── Marquee ── */
      .marquee-wrap {
        overflow: hidden;
        mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
      }

      /* ── Timeline dot glow ── */
      .timeline-dot {
        box-shadow: 0 0 0 4px rgba(99,102,241,0.15), 0 0 12px rgba(99,102,241,0.4);
      }
    </style>

    <!-- Particle system + scroll reveal -->
    <script>
      // ── Particle canvas ──────────────────────────────────────────
      const canvas = document.getElementById('particles') as HTMLCanvasElement;
      const ctx    = canvas?.getContext('2d');

      if (canvas && ctx) {
        const resize = () => {
          canvas.width  = window.innerWidth;
          canvas.height = window.innerHeight;
        };
        resize();
        window.addEventListener('resize', resize, { passive: true });

        const COLORS = ['#ffffff', '#f8fafc', '#f1f5f9', '#e2e8f0'];
        const stars: any[] = [];
        const ringParticles: any[] = [];
        const STAR_COUNT = Math.min(300, Math.floor(window.innerWidth / 4));
        const RING_COUNT = window.innerWidth > 768 ? 1200 : 600; 

        const EVENT_HORIZON_RADIUS = 110;

        // Init Stars
        for (let i = 0; i < STAR_COUNT; i++) {
          stars.push({
            x: Math.random() * canvas.width,
            y: Math.random() * canvas.height,
            vx: (Math.random() - 0.5) * 0.2,
            vy: (Math.random() - 0.5) * 0.2,
            size: Math.random() * 1.5 + 0.1,
            c: COLORS[Math.floor(Math.random() * COLORS.length)],
            o: Math.random() * 0.8 + 0.1,
            blinkRate: Math.random() * 0.015,
            blinkDir: Math.random() > 0.5 ? 1 : -1
          });
        }

        let mouse = { x: -9999, y: -9999 };
        window.addEventListener('mousemove', e => {
          mouse.x = e.clientX;
          mouse.y = e.clientY;
        }, { passive: true });

        const resetRingParticle = (i: number, initial=false) => {
            const angle = Math.random() * Math.PI * 2;
            
            // Concentrate particles in a Saturn-like ring
            const centralRadius = EVENT_HORIZON_RADIUS + 80;
            const variance = (Math.random() - 0.5) * (Math.random() - 0.5) * 400; 
            let radius = centralRadius + variance;
            // Prevent spawning inside the black hole
            radius = Math.max(EVENT_HORIZON_RADIUS + 5, radius);

            // Add some "stray" particles further out
            if (Math.random() > 0.9) radius += Math.random() * 200;

            ringParticles[i] = {
                angle,
                radius,
                size: Math.random() * 1.5 + 0.3,
                c: COLORS[Math.floor(Math.random() * COLORS.length)],
                o: initial ? (Math.random() * 0.7 + 0.1) : 0,
                speedOffset: Math.random() * 0.2 + 0.9,
                yOffset: (Math.random() - 0.5) * 6
            };
        };

        for(let i=0; i<RING_COUNT; i++) {
            resetRingParticle(i, true);
        }

        const draw = () => {
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          const cx = window.innerWidth >= 1024 ? canvas.width * 0.70 : canvas.width / 2;
          const cy = canvas.height / 2;

          // 1. Draw Starfield
          for (const s of stars) {
            // Apply slight orbital drift around the black hole
            const dx = s.x - cx;
            const dy = s.y - cy;
            const dist = Math.sqrt(dx*dx + dy*dy);
            
            if (dist > 0) {
                // tangential vector for rotation
                s.vx += (-dy / dist) * 0.015;
                s.vy += (dx / dist) * 0.015;
            }

            // Mouse repulsion functionality
            const mdx = s.x - mouse.x;
            const mdy = s.y - mouse.y;
            const mDist = Math.sqrt(mdx*mdx + mdy*mdy);
            if (mDist < 120) {
              const force = (120 - mDist) / 120;
              s.vx += (mdx / mDist) * force * 0.4;
              s.vy += (mdy / mDist) * force * 0.4;
            }

            // Apply friction and update position
            s.vx *= 0.98;
            s.vy *= 0.98;
            s.x += s.vx;
            s.y += s.vy;

            // Wrap around screen
            if (s.x < 0) s.x = canvas.width;
            if (s.x > canvas.width) s.x = 0;
            if (s.y < 0) s.y = canvas.height;
            if (s.y > canvas.height) s.y = 0;

            // Twinkling
            s.o += s.blinkRate * s.blinkDir;
            if (s.o >= 1) { s.o = 1; s.blinkDir = -1; }
            if (s.o <= 0.1) { s.o = 0.1; s.blinkDir = 1; }

            ctx.beginPath();
            ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
            ctx.fillStyle = s.c;
            ctx.globalAlpha = s.o;
            ctx.fill();
          }
          ctx.globalAlpha = 1;

          // 2. Physics Update for Ring
          for(let i=0; i<RING_COUNT; i++) {
             const p = ringParticles[i];
             
             // Kepler-like velocity (faster closer to center)
             const speed = (220 / p.radius) * p.speedOffset;
             p.angle += speed * 0.006;
             p.radius -= speed * 0.02; // Very slow inward spiral
             
             if (p.radius <= EVENT_HORIZON_RADIUS) {
                 resetRingParticle(i, false);
             } else if (p.o < 0.9) {
                 p.o += 0.015;
             }
          }

          const backParticles = [];
          const frontParticles = [];
          for (let i=0; i<RING_COUNT; i++) {
             const p = ringParticles[i];
             if (Math.sin(p.angle) < 0) {
                 backParticles.push(p);
             } else {
                 frontParticles.push(p);
             }
          }

          const renderParticle = (p: any) => {
             const alpha = p.radius < EVENT_HORIZON_RADIUS + 15 
                ? p.o * Math.max(0, (p.radius - EVENT_HORIZON_RADIUS)/15) 
                : p.o;

             const x = cx + Math.cos(p.angle) * p.radius;
             const y = cy + Math.sin(p.angle) * p.radius * 0.28 + p.yOffset; // 0.28 tilt gives the Saturn look

             ctx.beginPath();
             ctx.arc(x, y, p.size, 0, Math.PI * 2);
             ctx.fillStyle = p.c;
             ctx.globalAlpha = alpha;
             ctx.fill();
          };

          // Draw Back of Ring
          ctx.globalCompositeOperation = 'screen';
          backParticles.forEach(renderParticle);
          ctx.globalCompositeOperation = 'source-over';

          // 3. Draw Event Horizon (Pure Black Center)
          ctx.beginPath();
          ctx.arc(cx, cy, EVENT_HORIZON_RADIUS, 0, Math.PI * 2);
          ctx.fillStyle = '#000000';
          // Outer intense white photon ring
          ctx.shadowBlur = 50;
          ctx.shadowColor = '#ffffff'; 
          ctx.fill();
          
          // Second inner layer to clear shadow inside and make perfectly pitch black
          ctx.shadowBlur = 0;
          ctx.beginPath();
          ctx.arc(cx, cy, EVENT_HORIZON_RADIUS - 1, 0, Math.PI * 2);
          ctx.fillStyle = '#000000';
          ctx.fill();

          // Draw Front of Ring
          ctx.globalCompositeOperation = 'screen';
          frontParticles.forEach(renderParticle);
          ctx.globalCompositeOperation = 'source-over';

          requestAnimationFrame(draw);
        };
        draw();
      }

      // ── Scroll reveal ─────────────────────────────────────────────
      const revealEls = document.querySelectorAll('.reveal');
      const observer  = new IntersectionObserver(
        entries => {
          entries.forEach((entry, i) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = parseFloat(el.dataset.delay ?? '0');
              setTimeout(() => el.classList.add('revealed'), delay * 1000);
              observer.unobserve(el);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
      );
      revealEls.forEach(el => observer.observe(el));

      // ── Active nav highlight ───────────────────────────────────────
      const sections = document.querySelectorAll('section[id]');
      const navLinks = document.querySelectorAll('[data-navlink]');
      const navObserver = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              navLinks.forEach(link => {
                const href = (link as HTMLAnchorElement).getAttribute('href');
                link.classList.toggle('nav-active', href === '#' + entry.target.id);
              });
            }
          });
        },
        { threshold: 0.3 }
      );
      sections.forEach(s => navObserver.observe(s));
    </script>
  </body>
</html>
